# Supabase 설정
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# PompCore 연동 설정
# 운영: VITE_SHARED_DOMAIN=.pompcore.cc  (서브도메인 간 쿠키 공유)
# 개발: 빈 문자열 또는 항목 삭제 (localhost 전용)
VITE_SHARED_DOMAIN=.pompcore.cc
VITE_POMPCORE_URL=https://pompcore.cc

# Analytics
VITE_CLARITY_ID=your-clarity-project-id
VITE_ADSENSE_CLIENT=ca-pub-your-adsense-id
VITE_GA_MEASUREMENT_ID=G-your-measurement-id

# GitHub
GH_TOKEN=your-github-personal-access-token