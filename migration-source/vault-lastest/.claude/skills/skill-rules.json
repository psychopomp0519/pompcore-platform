{
    "version": "1.0",
    "description": "Vault 프로젝트용 스킬 활성화 트리거. React 19 + TypeScript + Tailwind CSS + Supabase 스택.",
    "skills": {
        "skill-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-skill for creating and managing Claude Code skills",
            "promptTriggers": {
                "keywords": [
                    "skill system", "create skill", "add skill",
                    "skill triggers", "skill rules", "skill-rules.json"
                ],
                "intentPatterns": [
                    "(how do|how does|explain).*?skill",
                    "(create|add|modify|build).*?skill"
                ]
            }
        },
        "vercel-react-best-practices": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "React 19 + TypeScript 성능 최적화 패턴 (Vercel Engineering 기반)",
            "promptTriggers": {
                "keywords": [
                    "component", "react", "성능", "performance",
                    "렌더링", "rendering", "memo", "Suspense", "최적화"
                ],
                "intentPatterns": [
                    "(create|add|make|build|update).*?(component|UI|page|modal|form)",
                    "(optimize|최적화).*?(component|rendering|bundle)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": ["src/**/*.tsx", "src/**/*.ts"],
                "pathExclusions": ["**/*.test.*", "**/tsconfig.json"],
                "contentPatterns": ["import.*from 'react'", "useState", "useEffect", "useMemo"]
            }
        },
        "error-tracking": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "에러 트래킹 및 모니터링 패턴",
            "promptTriggers": {
                "keywords": ["error handling", "exception", "error tracking", "에러 처리"],
                "intentPatterns": ["(add|implement|setup).*?(error handling|error tracking)"]
            }
        },
        "clean-code": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "개발자 친화적 코드 작성 가이드 (TypeScript/JavaScript)",
            "promptTriggers": {
                "keywords": ["코드 품질", "리팩토링", "refactor", "clean code", "컨벤션"],
                "intentPatterns": ["(refactor|리팩토링|개선).*?(code|코드)"]
            },
            "fileTriggers": {
                "pathPatterns": ["src/**/*.ts", "src/**/*.tsx"]
            }
        },
        "uxui-optimizer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "UX/UI 최적화 (디자인 시스템 원칙 기반)",
            "promptTriggers": {
                "keywords": ["UX", "UI", "디자인", "design", "레이아웃", "접근성"],
                "intentPatterns": ["(improve|개선|optimize).*?(UX|UI|디자인)"]
            },
            "fileTriggers": {
                "pathPatterns": ["src/components/**/*.tsx", "src/pages/**/*.tsx", "tailwind.config.ts"]
            }
        },
        "seo-geo-adsense": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "Google AdSense 수익화, SEO, GEO 최적화",
            "promptTriggers": {
                "keywords": ["SEO", "AdSense", "수익화", "메타 태그", "sitemap"],
                "intentPatterns": ["(setup|optimize).*?(SEO|AdSense|수익)"]
            }
        },
        "code-verifier": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "코드 검증 및 QA 파이프라인",
            "promptTriggers": {
                "keywords": ["검증", "verify", "코드 리뷰", "확인", "점검", "QA"],
                "intentPatterns": ["(검증|verify|review|확인|점검).*?(code|코드|프로젝트)"]
            }
        },
        "project-docs": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "프로젝트 문서 자동 갱신",
            "promptTriggers": {
                "keywords": ["문서", "documentation", "docs", "아키텍처"],
                "intentPatterns": ["(update|갱신|작성).*?(docs|문서)"]
            }
        },
        "plan-first": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "조사 -> 계획 -> 확인 -> 실행 워크플로우",
            "promptTriggers": {
                "keywords": ["만들어줘", "수정해줘", "구현해줘", "implement", "build"],
                "intentPatterns": ["(만들|수정|구현|추가|변경).*?(해줘|하자)"]
            }
        },
        "frontend-design": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "프로덕션급 프론트엔드 UI 디자인",
            "promptTriggers": {
                "keywords": ["디자인", "UI 디자인", "웹 디자인", "스타일링"],
                "intentPatterns": ["(create|design|디자인).*?(UI|page|component|화면)"]
            },
            "fileTriggers": {
                "pathPatterns": ["src/components/**/*.tsx", "src/pages/**/*.tsx"]
            }
        },
        "web-design-guidelines": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "웹 인터페이스 가이드라인 준수 검토",
            "promptTriggers": {
                "keywords": ["UI 검토", "접근성 검토", "디자인 감사", "audit"],
                "intentPatterns": ["(review|검토|audit).*?(UI|UX|접근성)"]
            }
        },
        "mermaid": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "low",
            "description": "Mermaid 다이어그램 생성",
            "promptTriggers": {
                "keywords": ["다이어그램", "diagram", "mermaid", "flowchart", "ERD"],
                "intentPatterns": ["(create|draw|그려|만들).*?(diagram|다이어그램|flowchart)"]
            }
        }
    },
    "notes": {
        "enforcement_types": {
            "suggest": "스킬 제안만 표시, 실행 차단 없음",
            "block": "스킬 사용 필수 (가드레일)",
            "warn": "경고 표시 후 진행 허용"
        },
        "priority_levels": {
            "critical": "최고 - 매칭 시 항상 트리거",
            "high": "높음 - 대부분 매칭에서 트리거",
            "medium": "중간 - 명확한 매칭에서 트리거",
            "low": "낮음 - 명시적 매칭에서만 트리거"
        }
    }
}
